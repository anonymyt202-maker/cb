# ============================================
#   Voice/Vote Battle Bot — Environment Config
#   TmuxCaseBot ekotizimining bir qismi
# ============================================

# Battle bot uchun Telegram bot tokeni (TmuxCaseBot'dan ALOHIDA, boshqa bot)
BOT_TOKEN=YOUR_BATTLE_BOT_TOKEN_HERE
BOT_USERNAME=YourBattleBotUsername
ADMIN_IDS=8512512542

# TmuxCaseBot Mini App URL — /start xabaridagi "Open App" tugmasi shu yerga olib boradi
TMUXCASE_WEBAPP_URL=https://your-domain.com
